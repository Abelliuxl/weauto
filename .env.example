# Primary text LLM (LongCat)
LONGCAT_BASE_URL=https://api.longcat.chat/openai
LONGCAT_API_KEY=replace_me

# SiliconFlow endpoints (vision + embedding, and optional DeepSeek fallback)
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=replace_me

# Optional alternate names if you want dedicated vars for DeepSeek:
# SILICONFLOW_DEEPSEEK_BASE_URL=https://api.siliconflow.cn/v1
# SILICONFLOW_DEEPSEEK_API_KEY=replace_me

# Optional Tavily key (used only when tavily_enabled=true)
TAVILY_API_KEY=replace_me

# Optional Brave Search key (used only when web_search_provider=brave and brave_enabled=true)
BRAVE_SEARCH_API_KEY=replace_me
